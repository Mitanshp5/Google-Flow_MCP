{
  "name": "google-flow-browser-mcp",
  "version": "1.0.0",
  "description": "MCP server for Google Flow (labs.google/fx/tools/flow) via browser automation",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start-browser": "powershell -ExecutionPolicy Bypass -File scripts/start-browser.ps1",
    "start-mcp": "powershell -ExecutionPolicy Bypass -File scripts/start-mcp.ps1",
    "register-opencode": "powershell -ExecutionPolicy Bypass -File scripts/register-opencode.ps1",
    "test": "powershell -ExecutionPolicy Bypass -File scripts/test-flow-image.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "playwright": "^1.51.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
